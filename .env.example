# ===================================================================
# Bridge HTTP 层
# ===================================================================

# Bridge HTTP 监听地址。platform 的 GATEWAY_WS_URL 指向这里的 /ws/agent；
# 同一端口承载 /api/push（platform 推生成文件）+ /api/download（platform 拉用户上传）。
# 不要用 :11960 —— 被 Container Hub 占。
BRIDGE_HTTP_ADDR=:11970

# State dir — 本地存储：blob（chat 文件）、wecom-chatid.json（chatId→reply target）。
BRIDGE_STATE_DIR=./runtime

# Log level: debug | info | warn | error
BRIDGE_LOG_LEVEL=info

# Shutdown grace (seconds)
BRIDGE_SHUTDOWN_TIMEOUT_SECONDS=10

# ===================================================================
# Platform 对端身份（ticket 三元组）
# -------------------------------------------------------------------
# bridge 启动时会基于这三个字段生成一个无签名 JWT 打印到 stdout，
# 你把它贴到 agent-platform 的 GATEWAY_JWT_TOKEN。
# bridge ↔ platform 的 ticket 校验 + /api/push + /api/download 鉴权都用它。
# ===================================================================
BRIDGE_AGENT_KEY=personal
BRIDGE_CHANNEL=wecom:personal
BRIDGE_USER_ID=local

# 可选：/api/upload 帧里的 url host。不填就只写相对路径，platform 会自己按
# GATEWAY_BASE_URL 拼，一般无需设置。
# BRIDGE_PUBLIC_BASE_URL=

# ===================================================================
# 企业微信 Bot（Phase 3；每个用户自己到企微后台申请的 AiBot 凭证，不共享）
# -------------------------------------------------------------------
# 申请入口：企业微信管理后台 → 应用管理 / 智能机器人 → 创建 AiBot
# 拿到 bot_id + secret 填到这里。
# ===================================================================
# 置 true 才会真的连企微；置 false 时 bridge 只对 platform 暴露协议、不收发企微消息。
WECOM_ENABLED=false

# 官方默认入口，个人场景通常不改。
WECOM_WS_URL=wss://openws.work.weixin.qq.com

# 必填（WECOM_ENABLED=true 时）
WECOM_BOT_ID=
WECOM_SECRET=

# 多实例场景下区分；个人单机写 default 即可。
WECOM_APP_KEY=default

# 心跳间隔（秒），默认 30。
WECOM_HEARTBEAT_SECONDS=30

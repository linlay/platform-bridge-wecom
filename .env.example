# ===================================================================
# Bridge HTTP 层
# ===================================================================
BRIDGE_HTTP_ADDR=:11970
BRIDGE_STATE_DIR=./runtime
BRIDGE_LOG_LEVEL=debug
BRIDGE_SHUTDOWN_TIMEOUT_SECONDS=10

# ===================================================================
# Platform 对端身份（与公司 aiagent-gateway 对齐，platform 侧路由规则可复用）
# ===================================================================
BRIDGE_AGENT_KEY=zenmi
BRIDGE_CHANNEL=wecom:xiaozhai
BRIDGE_USER_ID=local

# ===================================================================
# 企业微信 Bot
# ⚠️ 下面这对凭证是从 aiagent-gateway/gateway-core/src/main/resources/application-dev.yaml
#    直接复制的开发环境小宅。公司那份 Java gateway 跑起来会抢这条订阅——
#    测试时务必先停掉公司 gateway，测完及时切回去或申请一对你自己的。
# ===================================================================
WECOM_ENABLED=true
WECOM_WS_URL=wss://openws.work.weixin.qq.com
WECOM_HEARTBEAT_SECONDS=30

# ---- 单 bot 部署（legacy，最简单）----
# 仅设 WECOM_BOT_ID + WECOM_SECRET，bridge 会合成一个 appKey=default 的 bot。
WECOM_BOT_ID=
WECOM_SECRET=
WECOM_APP_KEY=default

# ---- 多 bot 部署 ----
# 创建 $BRIDGE_STATE_DIR/bots.json（或用 BRIDGE_BOTS_FILE 指其他路径），格式见 bots.example.json：
#   [{"id":"botAAA","secret":"xxx","appKey":"xiaozhai"},{"id":"botBBB","secret":"yyy","appKey":"assistant"}]
# bots.json 存在时优先走它，WECOM_BOT_ID 等 legacy 变量被忽略。
# appKey 必须唯一，bridge 按 chatId 反查 appKey 把 platform 的出站消息路由到对应 bot。
# BRIDGE_BOTS_FILE=/path/to/bots.json
